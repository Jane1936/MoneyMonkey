page {
  background: #f2f2f7;
  font-size: 28rpx;
  color: #1c1c1e;
}

.container {
  padding: 24rpx;
}

.ios-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.sub-title {
  font-size: 31rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.row {
  margin-bottom: 16rpx;
}

.label {
  color: #8e8e93;
  margin-bottom: 8rpx;
  display: block;
}

.input,
.picker {
  background: #f5f5f7;
  border: 1rpx solid #e5e5ea;
  border-radius: 14rpx;
  min-height: 72rpx;
  padding: 12rpx 16rpx;
  box-sizing: border-box;
}

.picker-content {
  min-height: 48rpx;
  display: flex;
  align-items: center;
}

.inline-row {
  display: flex;
  gap: 12rpx;
}

.flex-1 {
  flex: 1;
}

.currency-picker {
  width: 180rpx;
}

.primary-btn {
  background: #007aff;
  color: #fff;
  border: none;
  border-radius: 16rpx;
  margin-top: 10rpx;
}

.ghost-btn {
  background: #fff;
  color: #007aff;
  border: 1rpx solid #007aff;
  border-radius: 16rpx;
}

.warn { color: #ff3b30; }
.good { color: #34c759; }
.bad { color: #ff3b30; }

.list-item {
  border-bottom: 1rpx solid #ececf1;
  padding: 12rpx 0;
}

.list-item:last-child {
  border-bottom: none;
}

.segment {
  display: flex;
  background: #f1f1f5;
  border-radius: 14rpx;
  padding: 6rpx;
  margin-bottom: 14rpx;
}

.segment-item {
  flex: 1;
  text-align: center;
  padding: 10rpx 0;
  border-radius: 12rpx;
  color: #636366;
}

.segment-item.active {
  background: #fff;
  color: #007aff;
  font-weight: 600;
}

.chart-wrap {
  background: #f9f9fb;
  border-radius: 14rpx;
  padding: 12rpx;
}

.chart-canvas {
  width: 100%;
  height: 320rpx;
}
