page {
  background: #f3f4f6;
  font-size: 28rpx;
  color: #111827;
}

.container {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.06);
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.sub-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.row {
  margin-bottom: 14rpx;
}

.label {
  color: #6b7280;
  margin-bottom: 6rpx;
  display: block;
}

.input,
.picker,
button {
  background: #f9fafb;
  border: 1rpx solid #d1d5db;
  border-radius: 12rpx;
  min-height: 72rpx;
  padding: 12rpx 16rpx;
}

.primary-btn {
  background: #2563eb;
  color: #ffffff;
  border: none;
  margin-top: 10rpx;
}

.warn {
  color: #dc2626;
}

.good {
  color: #16a34a;
}

.bad {
  color: #dc2626;
}

.list-item {
  border-bottom: 1rpx solid #e5e7eb;
  padding: 12rpx 0;
}

.list-item:last-child {
  border-bottom: none;
}
